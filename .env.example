# PostgreSQL 資料庫設定
POSTGRES_USER=eq_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=eq_research
# 本機直接執行 prisma cli 時，設定 POSTGRES_HOST（預設 localhost）即可
# POSTGRES_HOST=localhost

# 應用程式密碼
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SESSION_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS_HERE

# LLM（提示詞合成）
CHAT_API_ENDPOINT=https://api.ithu.tw/v1
CHAT_MODEL_NAME=gpt-oss-120b
VISION_MODEL_NAME=gpt-oss-120b
CHAT_API_KEY=sk-xxx

# FLUX.1 圖像生成（本地自架）
FLUX_BASE_URL=http://flux:8000
# dev：高品質，需 HF_TOKEN，預設 guidance=3.5 / seq=512 / steps=20
# schnell：快速，公開模型，預設 guidance=0 / seq=256 / steps=4
FLUX_MODEL_ID=black-forest-labs/FLUX.1-dev
# FLUX_MODEL_ID=black-forest-labs/FLUX.1-schnell
# 留空則使用各 model 的預設值
FLUX_GUIDANCE_SCALE=
FLUX_MAX_SEQUENCE_LENGTH=
FLUX_STEPS=
FLUX_QUANT=bf16

# HuggingFace Token（FLUX.1-dev 需先接受授權，至 huggingface.co/settings/tokens 申請）
# 需先在 huggingface.co/black-forest-labs/FLUX.1-dev 接受授權
HF_TOKEN=hf_xxx

# Flux API 內部認證密鑰（nextjs 呼叫 flux 時使用，自行產生隨機字串）
FLUX_API_SECRET=CHANGE_ME_STRONG_FLUX_SECRET

# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=

# 開發模式允許的來源網域（逗號分隔）
ALLOWED_DEV_ORIGINS=

# 實際部署網域 / 允許的前端 Origin
APP_ORIGIN=
